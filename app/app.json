{
  "expo": {
    "scheme": "ayudalock",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AyudaLock to scan voucher QR codes."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "name": "app",
    "slug": "app"
  }
}
